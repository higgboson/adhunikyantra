{
  "expo": {
    "name": "ADHUNIK YANTRA",
    "slug": "adhunik-yantra",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "adhunik-yantra",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Scan wiring diagrams to identify circuits",
        "NSPhotoLibraryUsageDescription": "Upload wiring diagrams for circuit analysis"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0E17"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0E17"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Upload wiring diagrams for circuit analysis",
          "cameraPermission": "Scan wiring diagrams to identify circuits"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

